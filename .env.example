# Frontend env only.
# Every VITE_* value is public in the browser bundle.
# Do NOT put SOAP login/password, session tokens, player ids, or partner secrets here.
# Real auth/session/player/SOAP credentials must come from the host/backend at runtime,
# or from a backend/proxy that keeps them server-side.

# Local SOAP proxy path. Safe frontend config.
VITE_HIRANMANDI_SOAP_ENDPOINT=/soap-hiranmandi

# Use `soap` for the backend flow, or `mock` for UI-only local work.
VITE_HIRANMANDI_BACKEND_MODE=soap

# Safe frontend game id required by the iframe context.
VITE_HIRANMANDI_GAME_ID=hiranmandi

# Safe UI language default.
VITE_HIRANMANDI_LOCALE=en